# Copy this file to .env — the defaults below work immediately with SQLite,
# no server to install or configure. Nothing here needs to change to run
# `npm install && npm run db:setup && npm run dev`.
DATABASE_URL="file:./prisma/dev.db"

# Production (Postgres): comment out the line above, uncomment this one, and
# ALSO flip `datasource db { provider = ... }` in prisma/schema.prisma from
# "sqlite" to "postgresql" — see docs/DEPLOYMENT.md for the full sequence.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# NextAuth. The value below is a real, working local-dev secret (safe to
# use as-is — it signs nothing but your own local session cookies) so
# `npm run db:setup` can copy this file to `.env` and just work. Generate
# your own for anything beyond solo local development:
#   openssl rand -base64 32
NEXTAUTH_SECRET="tlQTt1Qn0UJR6CLjXLJrxD+Z9HpzVdzTsu/wx/2ks1I="
# The app's own public URL — required by NextAuth for callback/redirect
# construction. Use http://localhost:3000 for local development.
NEXTAUTH_URL="http://localhost:3000"
