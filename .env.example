# Copy this file to .env and fill in a real PostgreSQL connection string.
# PostgreSQL is the only supported database (development and production
# alike) — there is no SQLite fallback, so this value must point at a real
# reachable Postgres instance before any `db:*` script or `npm run dev`
# will work. See docs/DEPLOYMENT.md for local and Ubuntu VPS setup.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# NextAuth. Generate a real secret — never reuse this across environments,
# and never commit the real value:
#   openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_A_GENERATED_SECRET"
# The app's own public URL — required by NextAuth for callback/redirect
# construction. Use http://localhost:3000 for local development.
NEXTAUTH_URL="http://localhost:3000"
